# ============================================================
# Vite environment variables for TOEFL Allmyexam
# Copy this file to .env.local and fill in the values.
# ============================================================

# Optional: Override the Supabase Functions origin.
# Defaults to https://<PROJECT_ID>.supabase.co/functions/v1
# Set this when using a custom domain or a different deployment.
# VITE_SERVER_ORIGIN=https://xmdfbjfmiavuxlpzawan.supabase.co/functions/v1

# Optional: Override the edge-function path prefix.
# Defaults to /make-server-e46cd33a
# VITE_SERVER_BASE_PATH=/make-server-e46cd33a
